# =============================================================================
# dbgate deploy 환경변수 예시
# =============================================================================
# 사용법: cp .env.example .env 후 값을 변경하세요.
# .env 파일은 절대 커밋하지 마세요 (.gitignore에 포함됨).
# =============================================================================

# MySQL
MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_DATABASE=dbgate_test
MYSQL_USER=dbgate
MYSQL_PASSWORD=changeme_dbgate

# HAProxy stats 인증 (user:password)
HAPROXY_STATS_AUTH=admin:changeme_stats

# Dashboard Basic Auth (필수 — 미설정 시 서버 시작 실패)
DASHBOARD_AUTH_USER=admin
DASHBOARD_AUTH_PASSWORD=changeme_dashboard
